{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/objects/(.*)",
      "destination": "/api/[...path]"
    },
    {
      "source": "/((?!api|objects|assets).*)",
      "destination": "/index.html"
    }
  ]
}
