# =============================================================================
# VARIÁVEIS DE AMBIENTE — Claramente não sou um Escritor
# =============================================================================
# Copie este arquivo para .env.local para desenvolvimento local.
# No Vercel, configure estas variáveis em:
# Project Settings → Environment Variables
# =============================================================================

# ------------------------------------------------------------------------------
# BANCO DE DADOS (OBRIGATÓRIO)
# ------------------------------------------------------------------------------
# URL de conexão PostgreSQL.
# Serviços recomendados (gratuitos): Neon (neon.tech), Supabase (supabase.com)
#
# Formato: postgresql://usuario:senha@host:porta/banco?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/escritor?sslmode=require

# ------------------------------------------------------------------------------
# AUTENTICAÇÃO (OBRIGATÓRIO)
# ------------------------------------------------------------------------------
# String secreta aleatória para assinar as sessões.
# Gere uma: openssl rand -base64 32
SESSION_SECRET=sua_string_secreta_aqui_muito_longa_e_aleatoria

# Senha do painel admin do blog
ADMIN_PASSWORD=sua_senha_admin_aqui

# ------------------------------------------------------------------------------
# OPENAI — Assistente de escrita "Jarbas" (OBRIGATÓRIO para IA)
# ------------------------------------------------------------------------------
# Chave da API OpenAI. Obtenha em: https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# URL base da API (deixe em branco para usar o padrão OpenAI)
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# ------------------------------------------------------------------------------
# GOOGLE GEMINI — Transcrição de áudio (OBRIGATÓRIO para áudio)
# ------------------------------------------------------------------------------
# Chave da API Google Gemini. Obtenha em: https://aistudio.google.com/app/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=AIza...

# URL base do Gemini (deixe em branco para usar o padrão)
# AI_INTEGRATIONS_GEMINI_BASE_URL=

# ------------------------------------------------------------------------------
# NODE
# ------------------------------------------------------------------------------
NODE_ENV=production
